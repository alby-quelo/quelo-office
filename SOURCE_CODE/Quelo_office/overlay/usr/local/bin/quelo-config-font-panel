#!/bin/bash
# Pannello LXQt inferiore: dimensione caratteri (Menu, barra app, Spegni).
set -euo pipefail

_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
. "${_SCRIPT_DIR}/quelo-config-font-lib.sh"

if ! command -v zenity >/dev/null 2>&1; then
  exit 1
fi

current="$(quelo_font_read_panel_size)"
new_size="$(quelo_font_ask_size "Caratteri pannello inferiore" "${current}")" || exit 0
new_size="${new_size%.*}"

quelo_font_write_panel_size "${new_size}"
quelo_font_restart_panel

zenity --info \
  --title="Caratteri pannello inferiore" \
  --text="Dimensione impostata a ${new_size} pt.\n(Menu, barra applicazioni, Spegni)\n\nSalvata in ~/.config/quelo/\ncon «Desktop» nel salva sessione." \
  --width=380 2>/dev/null || true
