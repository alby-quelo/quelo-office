[Unit]
Description=Quelo Office - monta partizione persistence (ext4) se presente
DefaultDependencies=no
After=local-fs.target live-config.service
Before=getty@tty1.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/quelo-usb-mount-persist
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
